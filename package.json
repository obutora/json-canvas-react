{
  "name": "json-canvas-react",
  "version": "0.1.0",
  "description": "A dependency-light React framework for rendering and editing the JSON Canvas (jsoncanvas.org) open file format. DOM + CSS transform based: pan/zoom, drag, resize, edge drawing, markdown text nodes.",
  "type": "module",
  "license": "MIT",
  "author": "HagaKun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obutora/json-canvas-react.git"
  },
  "homepage": "https://github.com/obutora/json-canvas-react#readme",
  "bugs": {
    "url": "https://github.com/obutora/json-canvas-react/issues"
  },
  "keywords": [
    "json-canvas",
    "jsoncanvas",
    "obsidian",
    "canvas",
    "react",
    "infinite-canvas",
    "node-editor",
    "diagram"
  ],
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup && node scripts/copy-css.mjs",
    "typecheck": "tsc --noEmit",
    "demo:build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
